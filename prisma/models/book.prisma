model Book {
  id                String         @id @default(uuid()) @db.Uuid
  title             String
  author            String
  isbn              String         @unique
  shelfLocation     String
  totalQuantity     Int
  availableQuantity Int
  borrowRecords     BorrowRecord[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([title])
  @@index([author])
  
}
